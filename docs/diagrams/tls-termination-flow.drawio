<mxfile host="app.diagrams.net" agent="Codex" version="24.7.17"><diagram name="TLS Termination Flow"><mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="760" pageHeight="460" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="TLS Termination — HTTPS at the Gateway" style="text;html=1;align=center;verticalAlign=middle;fontColor=#111827;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="155" y="12" width="440" height="30" as="geometry"/></mxCell><mxCell id="tlssecret" value="&lt;b&gt;httpbin-tls secret&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;mkcert cert (localhost · 127.0.0.1)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#92400E;dashed=1;dashPattern=6 4;" vertex="1" parent="1"><mxGeometry x="200" y="60" width="220" height="52" as="geometry"/></mxCell><mxCell id="client" value="&lt;b&gt;Client&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;curl · browser&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#F3F4F6;strokeColor=#9CA3AF;fontColor=#374151;dashed=0;" vertex="1" parent="1"><mxGeometry x="20" y="224" width="150" height="66" as="geometry"/></mxCell><mxCell id="ctrl" value="&lt;b&gt;Ingress Controller&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;terminates TLS, reads secret&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#1E3A8A;dashed=0;" vertex="1" parent="1"><mxGeometry x="200" y="224" width="220" height="66" as="geometry"/></mxCell><mxCell id="svc" value="&lt;b&gt;Service&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;httpbin  :80&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#CCFBF1;strokeColor=#0D9488;fontColor=#115E59;dashed=0;" vertex="1" parent="1"><mxGeometry x="456" y="224" width="140" height="66" as="geometry"/></mxCell><mxCell id="pod" value="&lt;b&gt;Pod&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;httpbin  :8080&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#CCFBF1;strokeColor=#0D9488;fontColor=#115E59;dashed=0;" vertex="1" parent="1"><mxGeometry x="630" y="224" width="110" height="66" as="geometry"/></mxCell><mxCell id="redirect" value="&lt;font style=&quot;font-size:10px&quot;&gt;HTTP :8080  →  308 Permanent Redirect  →  HTTPS :8443&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F3F4F6;strokeColor=#9CA3AF;fontColor=#374151;dashed=1;dashPattern=5 4;" vertex="1" parent="1"><mxGeometry x="20" y="344" width="360" height="34" as="geometry"/></mxCell><mxCell id="e_tls" style="endArrow=block;html=1;rounded=1;strokeWidth=1;strokeColor=#D97706;dashed=1;dashPattern=6 4;" edge="1" parent="1" source="tlssecret" target="ctrl"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e1" value="HTTPS :8443 (encrypted)" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#6B7280;fontSize=10;fontColor=#6B7280;" edge="1" parent="1" source="client" target="ctrl"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="plain HTTP (decrypted)" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#6B7280;fontSize=10;fontColor=#6B7280;" edge="1" parent="1" source="ctrl" target="svc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#6B7280;" edge="1" parent="1" source="svc" target="pod"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="lg1" value="Solid → request path (HTTPS in, HTTP out)" style="text;html=1;align=left;verticalAlign=middle;fontColor=#6B7280;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="400" width="350" height="18" as="geometry"/></mxCell><mxCell id="lg2" value="Dashed → TLS secret read by gateway + HTTP redirect note" style="text;html=1;align=left;verticalAlign=middle;fontColor=#6B7280;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="422" width="420" height="18" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
